<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="AutomationSuite" parallel="false">

    <!-- E2E FLOW -->
    <test name="E2E Tests">
        <classes>
            <class name="runners.e2e.TestRunner"/>
        </classes>
    </test>

    <!-- UI FLOW -->
    <test name="UI Tests">
        <classes>
            <class name="runners.ui.UIRunner"/>
        </classes>
    </test>

    <!-- API FLOW -->
    <test name="API Tests">
        <classes>
            <class name="runners.api.APIRunner"/>
        </classes>
    </test>

    <!-- NEGATIVE TESTS -->
    <test name="Negative Tests">
        <classes>
            <class name="runners.negative.NegativeRunner"/>
        </classes>
    </test>

</suite>